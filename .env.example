# OpenAI API Key
OPENAI_API_KEY=sua_openai_api_key_aqui

# Database Supabase
DATABASE_URL=postgresql://user:password@host:5432/database

# Google OAuth
GOOGLE_CLIENT_ID=seu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
GOOGLE_CALLBACK_URL=https://seu-dominio.vercel.app/api/auth/google/callback

# Session Secret (gere uma chave aleatória segura)
SESSION_SECRET=sua_chave_secreta_min_32_caracteres

# Brevo SMTP (use a SMTP Key, não a API Key)
BREVO_API_KEY=sua_brevo_smtp_key_aqui

# Frontend URL (para CORS)
FRONTEND_URL=https://seu-dominio.vercel.app

# Environment
NODE_ENV=production
