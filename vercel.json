{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/server.js": {
      "memory": 2048,
      "maxDuration": 60,
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
